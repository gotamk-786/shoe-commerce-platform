// Prisma schema for Thirfy Shoes backend

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  processing
  paid
  shipped
  delivered
  cancelled
}

enum UserRole {
  admin
  customer
}

enum DeliveryCoverageType {
  radius
  polygon
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  sellPrice   Int
  costPrice   Int
  discount    Int?
  condition   String?
  gender      String?
  sizes       Json?
  tags        Json?
  metadata    Json?
  stock       Int
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  images      Json?
  categoryId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
  variants    ProductVariant[]
  reviews     Review[]
  wishlists   WishlistItem[]

  category    Category? @relation(fields: [categoryId], references: [id])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  color       String
  priceOverride Int?
  images      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sizes       VariantSize[]
  orderItems  OrderItem[]

  @@index([productId])
}

model VariantSize {
  id         String   @id @default(cuid())
  variantId  String
  sizeUS     String?
  sizeEU     String?
  stock      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  coverUrl     String?
  twoFactorEnabled Boolean @default(false)
  twoFactorMethod  String?
  isBlocked    Boolean  @default(false)
  role         UserRole @default(customer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  reviews      Review[]
  wishlists    WishlistItem[]
  addresses    Address[]
  paymentMethods PaymentMethod[]
  notificationPreference NotificationPreference?
  preferences  UserPreference?
  supportTickets SupportTicket[]
  returnRequests ReturnRequest[]
  activityLogs ActivityLog[]
  twoFactorTokens TwoFactorToken[]
  wishlistShares WishlistShare[]
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  fullName  String?
  fullAddress String?
  houseNo   String?
  street    String
  landmark  String?
  area      String?
  city      String
  state     String
  zip       String
  postalCode String?
  country   String
  phone     String
  lat       Float?
  lng       Float?
  placeId   String?
  deliveryNotes String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  provider    String
  label       String
  maskedNumber String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationPreference {
  id           String   @id @default(cuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  smsEnabled   Boolean  @default(false)
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  lastSentAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  sizeUS    String?
  sizeEU    String?
  brands    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ReturnRequest {
  id        String   @id @default(cuid())
  userId    String
  orderId   String
  reason    String
  status    String   @default("requested")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TwoFactorToken {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model WishlistShare {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  status    OrderStatus @default(processing)
  subTotal  Int         @default(0)
  discountTotal Int @default(0)
  shippingFee Int       @default(0)
  total     Int
  couponCode String?
  shipping  Json?
  deliveryAddress Json?
  deliveryZoneId String?
  deliveryZoneName String?
  codAvailableAtOrderTime Boolean?
  estimatedDeliveryTimeAtOrderTime String?
  paymentMethod String?
  courierName String?
  trackingNumber String?
  trackingUrl String?
  placedAt  DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]
  returnRequests ReturnRequest[]

  user      User        @relation(fields: [userId], references: [id])
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
}

model DeliveryZone {
  id        String   @id @default(cuid())
  name      String
  city      String
  coverageType DeliveryCoverageType
  centerLat Float?
  centerLng Float?
  radiusKm  Float?
  polygonJson Json?
  shippingFee Int      @default(0)
  estimatedDeliveryTime String
  codAvailable Boolean @default(true)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orders     Order[]

  @@index([city, isActive])
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  type       String
  value      Int
  active     Boolean  @default(true)
  usageLimit Int?
  usedCount  Int      @default(0)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  productId       String
  variantId       String?
  color           String?
  sizeUS          String?
  sizeEU          String?
  name            String
  quantity        Int
  soldPrice       Int
  costPriceAtSale Int
  image           String?
  size            String?
  createdAt       DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([createdAt])
}
